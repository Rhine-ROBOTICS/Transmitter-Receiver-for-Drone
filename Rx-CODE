#include <SPI.h>
#include <RF24.h>
#include <Servo.h>

// =====================================================
// NRF24L01
// =====================================================

RF24 radio(9, 10);  // CE, CSN

const byte RADIO_ADDRESS[6] = "00001";
const uint16_t PACKET_ID = 24680;

// =====================================================
// Receiver PWM outputs
// =====================================================

const byte CH1_OUTPUT_PIN = 2;
const byte CH2_OUTPUT_PIN = 3;
const byte CH3_OUTPUT_PIN = 4;
const byte CH4_OUTPUT_PIN = 5;
const byte CH5_OUTPUT_PIN = 6;

Servo ch1Output;
Servo ch2Output;
Servo ch3Output;
Servo ch4Output;
Servo ch5Output;

// =====================================================
// Radio packet
// Must exactly match transmitter
// =====================================================

struct DataPacket {
  uint16_t packetID;

  uint16_t ch1;
  uint16_t ch2;
  uint16_t ch3;
  uint16_t ch4;
  uint16_t ch5;

  uint32_t counter;
};

DataPacket data = {
  0,
  1500,
  1500,
  1000,
  1500,
  1000,
  0
};

// =====================================================
// Failsafe settings
// =====================================================

const unsigned long FAILSAFE_TIMEOUT = 500;

unsigned long lastValidPacketTime = 0;
unsigned long lastSerialTime = 0;

uint32_t lastCounter = 0;

bool connected = false;

// =====================================================
// Write all channels
// =====================================================

void writeChannels() {
  ch1Output.writeMicroseconds(data.ch1);
  ch2Output.writeMicroseconds(data.ch2);
  ch3Output.writeMicroseconds(data.ch3);
  ch4Output.writeMicroseconds(data.ch4);
  ch5Output.writeMicroseconds(data.ch5);
}

// =====================================================
// Safe channel values
// =====================================================

void applyFailsafe() {
  data.ch1 = 1500;  // Roll centre
  data.ch2 = 1500;  // Pitch centre
  data.ch3 = 1000;  // Throttle minimum
  data.ch4 = 1500;  // Yaw centre
  data.ch5 = 1000;  // AUX off

  writeChannels();
}

// =====================================================
// Validate incoming packet
// =====================================================

bool packetIsValid(const DataPacket &packet) {
  if (packet.packetID != PACKET_ID) {
    return false;
  }

  if (packet.ch1 < 900 || packet.ch1 > 2100) {
    return false;
  }

  if (packet.ch2 < 900 || packet.ch2 > 2100) {
    return false;
  }

  if (packet.ch3 < 900 || packet.ch3 > 2100) {
    return false;
  }

  if (packet.ch4 < 900 || packet.ch4 > 2100) {
    return false;
  }

  if (packet.ch5 < 900 || packet.ch5 > 2100) {
    return false;
  }

  return true;
}

// =====================================================
// Setup
// =====================================================

void setup() {
  Serial.begin(115200);

  ch1Output.attach(CH1_OUTPUT_PIN, 900, 2100);
  ch2Output.attach(CH2_OUTPUT_PIN, 900, 2100);
  ch3Output.attach(CH3_OUTPUT_PIN, 900, 2100);
  ch4Output.attach(CH4_OUTPUT_PIN, 900, 2100);
  ch5Output.attach(CH5_OUTPUT_PIN, 900, 2100);

  applyFailsafe();

  if (!radio.begin()) {
    Serial.println("ERROR: Receiver NRF not detected");

    while (true) {
      applyFailsafe();
      delay(20);
    }
  }

  radio.openReadingPipe(0, RADIO_ADDRESS);

  radio.setPALevel(RF24_PA_LOW);
  radio.setDataRate(RF24_250KBPS);
  radio.setChannel(76);
  radio.setCRCLength(RF24_CRC_16);

  radio.setAutoAck(true);

  radio.disableDynamicPayloads();
  radio.setPayloadSize(sizeof(DataPacket));
  radio.flush_rx();

  radio.startListening();

  Serial.println("5-channel receiver ready");
  Serial.println("Waiting for transmitter...");
}

// =====================================================
// Loop
// =====================================================

void loop() {
  if (radio.available()) {
    DataPacket incoming;

    while (radio.available()) {
      radio.read(&incoming, sizeof(incoming));
    }

    if (packetIsValid(incoming)) {
      data = incoming;

      lastCounter = incoming.counter;
      lastValidPacketTime = millis();

      connected = true;

      data.ch1 = constrain(data.ch1, 1000, 2000);
      data.ch2 = constrain(data.ch2, 1000, 2000);
      data.ch3 = constrain(data.ch3, 1000, 2000);
      data.ch4 = constrain(data.ch4, 1000, 2000);
      data.ch5 = constrain(data.ch5, 1000, 2000);

      writeChannels();
    }
  }

  if (millis() - lastValidPacketTime > FAILSAFE_TIMEOUT) {
    if (connected) {
      Serial.println("SIGNAL LOST - FAILSAFE");
    }

    connected = false;
    applyFailsafe();
  }

  if (millis() - lastSerialTime >= 250) {
    lastSerialTime = millis();

    Serial.print("Link: ");
    Serial.print(
      connected
      ? "CONNECTED"
      : "DISCONNECTED"
    );

    Serial.print(" | CH1:");
    Serial.print(data.ch1);

    Serial.print(" CH2:");
    Serial.print(data.ch2);

    Serial.print(" CH3:");
    Serial.print(data.ch3);

    Serial.print(" CH4:");
    Serial.print(data.ch4);

    Serial.print(" CH5:");
    Serial.println(data.ch5);
  }

  delay(5);
}
